# Copy to secrets.yaml (gitignored). Secrets referenced by enphase-powerpack.yaml:
wifi_ssid: "YOUR_WIFI_SSID"
wifi_password: "YOUR_WIFI_PASSWORD"
fallback_ap_password: "changeme123"                          # fallback AP (WPA, 8+ chars)
ota_password: "YOUR_OTA_PASSWORD"
enphase_powerpack__encryption-key: "GENERATE_32_BYTE_BASE64" # openssl rand -base64 32

# Note: the PowerPack BLE MAC is NOT a secret — it's a substitution in enphase-powerpack.yaml.
