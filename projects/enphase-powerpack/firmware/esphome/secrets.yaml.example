# Copy to secrets.yaml (gitignored). ohmward-lab shared conventions:
wifi_ssid: "YOUR_WIFI_SSID"
wifi_password: "YOUR_WIFI_PASSWORD"
fallback_password: "changeme123"
api_encryption_key: "GENERATE_A_32_BYTE_BASE64_KEY_HERE"   # openssl rand -base64 32
ota_password: "YOUR_OTA_PASSWORD"

# Extra secret this device needs (device-specific):
powerpack_ble_mac: "AA:BB:CC:DD:EE:FF"                     # PowerPack BLE MAC (scan PES_<serial>)
